#!/usr/bin/env python3
"""
Pre-commit hook for detecting secrets and credentials in code
Runs before every commit to prevent accidental secret commits
"""

import re
import sys
import subprocess

# Patterns to detect common secrets
SECRET_PATTERNS = {
    'mongodb_uri': r'mongodb\+srv://[a-zA-Z0-9]+:[a-zA-Z0-9]+@',
    'jwt_secret': r'JWT_SECRET\s*=\s*["\'][^"\']{10,}["\']',
    'api_key': r'(api_key|apikey|api-key)\s*[:=]\s*["\'][^"\']{8,}["\']',
    'aws_key': r'AKIA[0-9A-Z]{16}',
    'private_key': r'-----BEGIN (RSA|DSA|EC|OPENSSH|PRIVATE) KEY-----',
    'github_token': r'gh[a-z]_[A-Za-z0-9_]{36,255}',
    'vercel_token': r'vercel_[a-zA-Z0-9]{20,}',
}

# Files to skip
SKIP_PATTERNS = [
    r'\.env\.example$',
    r'\.env\.local\.example$',
    r'\.git/',
    r'node_modules/',
    r'\.venv/',
    r'__pycache__/',
    r'\.md$',
    r'\.txt$',
]


def should_skip_file(filepath):
    """Check if file should be skipped"""
    for pattern in SKIP_PATTERNS:
        if re.search(pattern, filepath):
            return True
    return False


def check_file_for_secrets(filepath):
    """Check a file for secrets"""
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
            content = f.read()
    except Exception as e:
        print(f"⚠️  Could not read file {filepath}: {e}")
        return False

    found_secrets = False
    
    for secret_type, pattern in SECRET_PATTERNS.items():
        if re.search(pattern, content, re.IGNORECASE):
            print(f"❌ SECURITY ALERT: Potential {secret_type.upper()} detected in {filepath}")
            found_secrets = True

    return found_secrets


def main():
    """Main pre-commit hook"""
    # Get staged files
    result = subprocess.run(
        ['git', 'diff', '--cached', '--name-only'],
        capture_output=True,
        text=True
    )
    
    staged_files = result.stdout.strip().split('\n')
    staged_files = [f for f in staged_files if f]

    print("🔐 Running security check on staged files...")
    
    found_issues = False
    for filepath in staged_files:
        if should_skip_file(filepath):
            continue
        
        if check_file_for_secrets(filepath):
            found_issues = True

    if found_issues:
        print("\n❌ COMMIT BLOCKED: Secrets detected!")
        print("\n💡 Fix suggestions:")
        print("   1. Move secrets to .env or .env.local files (already in .gitignore)")
        print("   2. Verify .gitignore includes all sensitive files")
        print("   3. Use environment variables in your application")
        print("   4. If this was accidental, rotate the exposed secrets immediately!")
        print("\n📖 See SECURITY_CHECKLIST.md for more information")
        return 1

    print("✅ Security check passed - no secrets detected!")
    return 0


if __name__ == '__main__':
    sys.exit(main())
